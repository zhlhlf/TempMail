# ==============================
# 基础配置
# 一般只需要改这一段
# ==============================

# 必填：服务器公网 IP（用于 MX 校验和 SPF 提示）
SMTP_SERVER_IP=1.2.3.4


# HTTP 监听端口
PORT=8080

# SMTP 监听端口
SMTP_PORT=25

# SQLite 数据库路径
API_DB_PATH=./data/tempmail.db

# ==============================
# 高级配置
# 不改也能正常运行；以下均为程序默认值
# ==============================

# SMTP 对外标识域名；未设置时优先使用 SMTP_HOSTNAME，否则默认 localhost
# SMTP_DOMAIN=localhost

# 管理员 API Key 文件输出路径
# ADMIN_KEY_FILE=./data/admin.key

# API 限流：窗口期内每个令牌最多请求数
# RATE_LIMIT=500

# API 限流窗口，单位秒
# RATE_WINDOW=60

# SMTP 单封邮件最大字节数（默认约 10 MB）
# SMTP_MAX_MESSAGE_BYTES=10240000

# SMTP 单次会话最多允许的收件人数
# SMTP_MAX_RECIPIENTS=100

# SMTP 读超时，单位秒
# SMTP_READ_TIMEOUT=30

# SMTP 写超时，单位秒
# SMTP_WRITE_TIMEOUT=30
